# Copy to .env and fill secrets. Everything has a working default for docker-compose.

# --- Database ---
DB_BACKEND=postgres                 # postgres | sqlite
POSTGRES_DSN=postgresql+psycopg://vaic:vaic@postgres:5432/vaic
SQLITE_PATH=./data/vaic.db

# --- OpenSearch ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
OPENSEARCH_INDEX=provisions

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vaic_neo4j

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ============================ LLM ============================
# Đổi provider chỉ cần 3 dòng: LLM_PROVIDER + LLM_MODEL + key tương ứng.
# Thiếu key / SDK, hoặc DEMO_MODE=true  ->  tự dùng mock (chạy offline, không gọi API).
LLM_PROVIDER=google                 # google | openai | anthropic | mock
LLM_MODEL=gemini-flash-latest
LLM_TEMPERATURE=0.0

# Keys — điền đúng cái của provider đang chọn (đừng thêm comment sau dấu = ở dòng key rỗng).
# Lấy key: google -> aistudio.google.com/apikey · anthropic -> console.anthropic.com · openai -> platform.openai.com/api-keys
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gợi ý model theo provider (đặt vào LLM_MODEL):
#   google    -> gemini-flash-latest | gemini-3.5-flash | gemini-2.0-flash | gemini-2.5-pro
#   anthropic -> claude-sonnet-4-6 | claude-opus-4-8 | claude-haiku-4-5-20251001
#   openai    -> gpt-4o | gpt-4o-mini | o3-mini
# ============================================================

# --- Auth ---
JWT_SECRET=change-me-in-prod

# --- Runtime ---
FILE_STORAGE_DIR=./data/storage
RETRIEVAL_TOP_K=8
# demo_mode=true swaps OpenSearch/Neo4j/LLM for in-memory stubs so the app runs
# on a laptop with no docker. Set false for the real 4-store deployment.
DEMO_MODE=false
